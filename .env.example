# ─────────────────────────────────────────────────────────────────────────────
# .env.example — template for the secrets that drive the deployed stack.
#
# Copy this to ".env" (which is git-ignored) and fill in real values:
#     cp .env.example .env
#
# deploy.sh base64-encodes .env into the Terraform `env` variable. At boot the
# VM's cloud-init decodes it into /opt/repo/docker/.env, so THIS file is the
# single source of truth for the WordPress/MySQL credentials in the cloud.
# ─────────────────────────────────────────────────────────────────────────────

# ── MySQL ────────────────────────────────────────────────────
# MYSQL_ROOT_PASSWORD / MYSQL_PASSWORD must match the seed DB in cloud-1.
MYSQL_ROOT_PASSWORD=CHANGE_ME_root_2026!
MYSQL_DATABASE=cooldatabase
MYSQL_USER=cooluser
MYSQL_PASSWORD=CHANGE_ME_db_2026!

# ── WordPress DB connection ──────────────────────────────────
WORDPRESS_DB_HOST=mysql
WORDPRESS_DB_NAME=cooldatabase
WORDPRESS_DB_USER=cooluser
WORDPRESS_DB_PASSWORD=CHANGE_ME_db_2026!

# ── phpMyAdmin ───────────────────────────────────────────────
PMA_HOST=mysql

# ── WordPress site + admin (used by cloud-1's wp-setup.sh) ───
# For a real cloud deploy set WP_URL to the VM's public IP or domain
# (e.g. https://20.x.x.x), NOT localhost — otherwise WordPress redirects away.
WP_URL=https://localhost
WP_TITLE="La Nube del Gato Argentino"
WP_ADMIN_USER=elgatoargentino
WP_ADMIN_PASSWORD=CHANGE_ME_admin_2026!
WP_ADMIN_EMAIL=test@test.com

# ── Emergency SSH fallback (OPTIONAL) ─────────────────────────
# If BOTH are set, cloud-init creates a sudo user with this login/password and
# enables SSH password login — a backup way in if the root key ever fails.
# Leave blank to disable (password auth stays off). Use a STRONG password:
# this box has a public IP, so a weak password will get brute-forced. No ':'.
# These lines are stripped from the .env before Docker starts (containers
# never see them). Root itself stays key-only.
EMERGENCY_USER=emergency
EMERGENCY_PASSWORD=CHANGE_ME_emergency_2026!
