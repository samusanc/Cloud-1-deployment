#cloud-config
# Allow key-based root SSH login — the eval requires connecting AS root
# (connecting as a sudo user is treated as cheating). Azure forbids creating
# the VM with admin_username=root, so we provision as 'adminuser' and copy its
# authorized key to root in runcmd below.
disable_root: false
write_files:
  - path: /etc/ssh/sshd_config.d/99-permit-root.conf
    content: |
      PermitRootLogin prohibit-password
packages:
  - git
  - docker.io
  - docker-compose
  - ufw
  - openssl
runcmd:
  # Enable root login with the same key adminuser received, then reload sshd.
  - install -d -m 700 /root/.ssh
  - cp /home/adminuser/.ssh/authorized_keys /root/.ssh/authorized_keys
  - chmod 600 /root/.ssh/authorized_keys
  - systemctl restart ssh
  - growpart /dev/sda 1
  - resize2fs /dev/sda1
  - |
    timeout 300 sh -c 'until ping -c 1 github.com; do sleep 2; done'
    # >>> APP REPO <<< the VM clones this at boot and runs its docker/setup.sh.
    # To deploy Andres' repo instead, swap the URL below for:
    #   https://github.com/andresmejiaro/cloud-1
    git clone https://github.com/samusanc/cloud-1 /opt/repo
    echo ${env} | base64 -d > /opt/repo/docker/.env
    # Override WP_URL with this VM's real public IP (injected by Terraform) so
    # WordPress builds correct asset/link/comment URLs instead of localhost.
    if grep -q '^WP_URL=' /opt/repo/docker/.env; then
      sed -i "s#^WP_URL=.*#WP_URL=https://${public_ip}#" /opt/repo/docker/.env
    else
      echo "WP_URL=https://${public_ip}" >> /opt/repo/docker/.env
    fi
    if [ -f /opt/repo/docker/setup.sh ]; then
      bash /opt/repo/docker/setup.sh
    else
      echo "Error: setup.sh not found after clone" >&2
    fi
