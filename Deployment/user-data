#cloud-config
packages:
  - git
  - docker.io
  - docker-compose
  - ufw
  - openssl
runcmd:
  - growpart /dev/sda 1
  - resize2fs /dev/sda1
  - |
    timeout 300 sh -c 'until ping -c 1 github.com; do sleep 2; done'
    git clone https://github.com/andresmejiaro/cloud-1 /opt/repo
    echo ${env} | base64 -d > /opt/repo/docker/.env
    if [ -f /opt/repo/docker/setup.sh ]; then
      bash /opt/repo/docker/setup.sh
    else
      echo "Error: setup.sh not found after clone" >&2
    fi
